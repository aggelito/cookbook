---
import type { CollectionEntry } from "astro:content";

type Recipe = CollectionEntry<"recipes">;
type Step = NonNullable<Recipe["data"]["steps"]>[number];

interface Props {
  step: Step;
  stepId: string;
  recipeId: string;
  index: number;
}

const { step, stepId, recipeId, index } = Astro.props;
---

<div
  class="recipe-step group card cursor-pointer border border-base-300 bg-base-100 shadow-sm transition-all duration-300 ease-in-out hover:border-emerald-500 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-base-200"
  data-recipe-id={recipeId}
  data-step-id={stepId}
  data-type="step"
  role="button"
  tabindex="0"
  aria-pressed="false"
>
  <div class="card-body gap-3 p-5">
    <div class="flex items-baseline gap-3">
      <span class="shrink-0 text-lg font-bold text-emerald-700">
        {index + 1}.
      </span>
      <div class="min-w-0 flex-1">
        <h4 class="m-0 text-lg font-semibold leading-snug text-base-content">{step.title}</h4>
        <div class="mt-2 leading-7 text-base-content/75" set:html={step.description} />
      </div>
    </div>
  </div>
</div>
