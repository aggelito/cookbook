---
import type { CollectionEntry } from "astro:content";
import IngredientRow from "./IngredientRow.astro";
import t from "../../i18n";

type Recipe = CollectionEntry<"recipes">;

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
---

<aside class="recipe-ingredients-section card border border-base-300 bg-base-100 shadow-sm lg:sticky lg:top-6">
  <div class="card-body gap-5 p-5 sm:p-6">
    <div>
      <h2 class="m-0 text-2xl font-semibold text-base-content">{t("recipe.ingredients")}</h2>
    </div>

    {
      recipe.data.ingredients && recipe.data.ingredients.length > 0 && (
        <ul class="m-0 space-y-1 p-0">
          {recipe.data.ingredients.map((ingredient, index) => (
            <IngredientRow ingredient={ingredient} itemId={`ingredient-${index}`} recipeId={recipe.id} />
          ))}
        </ul>
      )
    }

    {
      recipe.data.ingredientGroups && recipe.data.ingredientGroups.length > 0 && (
        <div class="space-y-5">
          {recipe.data.ingredientGroups.map((group, groupIndex) => (
            <section>
              <h3 class="m-0 mb-2 text-base font-semibold text-base-content/80">{group.groupName}</h3>
              <ul class="m-0 space-y-1 p-0">
                {group.ingredients.map((ingredient, ingredientIndex) => (
                  <IngredientRow
                    ingredient={ingredient}
                    itemId={`ingredient-group-${groupIndex}-${ingredientIndex}`}
                    recipeId={recipe.id}
                  />
                ))}
              </ul>
            </section>
          ))}
        </div>
      )
    }

    <div class="card-actions grid grid-cols-1 gap-2 pt-2 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
      <button
        id="reset-ingredients-btn"
        class="btn btn-ghost btn-sm"
        data-recipe-id={recipe.id}
        data-confirm-message={t("recipe.confirmReset")}
      >
        {t("recipe.resetIngredients")}
      </button>
      <button
        id="copy-shopping-list-btn"
        class="btn btn-primary btn-sm bg-emerald-600 hover:bg-emerald-700"
        data-recipe-id={recipe.id}
        data-copied-label={t("recipe.copied")}
      >
        {t("recipe.copyShoppingList")}
      </button>
    </div>
  </div>
</aside>
