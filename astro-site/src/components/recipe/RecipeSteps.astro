---
import type { CollectionEntry } from "astro:content";
import StepBlock from "./StepBlock.astro";
import t from "../../i18n";

type Recipe = CollectionEntry<"recipes">;

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
---

<section class="recipe-steps-section">
  {
    recipe.data.steps && recipe.data.steps.length > 0 && (
      <div class="space-y-4">
        <div>
          <h2 class="m-0 text-3xl font-semibold text-base-content">{t("recipe.steps")}</h2>
        </div>
        {recipe.data.steps.map((step, index) => (
          <StepBlock step={step} stepId={`step-${index}`} recipeId={recipe.id} index={index} />
        ))}
      </div>
    )
  }

  {
    recipe.data.stepGroups && recipe.data.stepGroups.length > 0 && (
      <div class="space-y-6">
        <div>
          <h2 class="m-0 text-3xl font-semibold text-base-content">{t("recipe.steps")}</h2>
        </div>
        {recipe.data.stepGroups.map((group, groupIndex) => (
          <section class="space-y-4">
            <h3 class="m-0 py-3 text-xl font-semibold text-base-content/80">{group.groupName}</h3>
            {group.steps.map((step, stepIndex) => (
              <StepBlock
                step={step}
                stepId={`step-group-${groupIndex}-${stepIndex}`}
                recipeId={recipe.id}
                index={stepIndex}
              />
            ))}
          </section>
        ))}
      </div>
    )
  }

  <button
    id="reset-steps-btn"
    class="btn btn-outline mt-5"
    data-recipe-id={recipe.id}
    data-confirm-message={t("recipe.confirmResetSteps")}
  >
    {t("recipe.resetSteps")}
  </button>
</section>
