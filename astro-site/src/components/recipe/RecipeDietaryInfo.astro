---
import type { CollectionEntry } from "astro:content";
import t from "../../i18n";

type Recipe = CollectionEntry<"recipes">;

interface Props {
  dietaryInfo: Recipe["data"]["dietaryInfo"];
}

const { dietaryInfo } = Astro.props;

const items = dietaryInfo ? [
  [t("recipe.vegetarian"), dietaryInfo.vegetarian],
  [t("recipe.vegan"), dietaryInfo.vegan],
  [t("recipe.glutenFree"), dietaryInfo.glutenFree],
  [t("recipe.dairyFree"), dietaryInfo.dairyFree],
  [t("recipe.nutFree"), dietaryInfo.nutFree],
  [t("recipe.lowCarb"), dietaryInfo.lowCarb],
] as const : [];
---

<section class="dietary-info-section mt-6">
  {
    dietaryInfo && (
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body gap-4 p-5 sm:p-6">
          <h2 class="m-0 text-xl font-semibold text-base-content">{t("recipe.dietaryInfo")}</h2>
          <ul class="m-0 flex flex-wrap gap-2 p-0">
            {items.map(([label, enabled]) => (
              <li class="list-none">
                <span class:list={["badge py-3", enabled ? "badge-success" : "badge-outline text-base-content/60"]}>
                  {label} {enabled ? t("common.yes") : t("common.no")}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )
  }
</section>
