---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const recipes = await getCollection("recipes");
---

<BaseLayout title="Recept">
  <div class="navbar bg-base-200 shadow-md p-2">
    <div class="flex-1">
      <a class="btn btn-ghost text-xl" href="/">Kokboken</a>
    </div>
    <div class="flex-none gap-2">
      <!-- RSS Feed Button with DaisyUI -->
      <button class="btn btn-sm btn-primary bg-emerald-600 hover:bg-emerald-700 text-white gap-2" title="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 19.5v-.75a7.5 7.5 0 0 0-7.5-7.5H4.5m0-6.75h.75c7.87 0 14.25 6.38 14.25 14.25v.75M6 18.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
        </svg>
        <span class="hidden sm:inline">RSS</span>
      </button>
      <a href="/rss.xml" class="btn btn-sm btn-outline border-emerald-600 text-emerald-700 hover:bg-emerald-50 gap-2" title="RSS Flöde">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 19.5v-.75a7.5 7.5 0 0 0-7.5-7.5H4.5m0-6.75h.75c7.87 0 14.25 6.38 14.25 14.25v.75M6 18.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
        </svg>
        <span class="hidden sm:inline">RSS Flöde</span>
      </a>
    </div>
  </div>
  
  <div class="prose mx-auto py-8 px-6 bg-base-100 card card-border border-base-300">
    <ul>
      {
        recipes.map((recipe) => (
          <li class="flex items-center gap-4 p-3 hover:bg-base-200 rounded-lg transition-colors cursor-pointer group">
            <h3>
              <a href={`/recipes/${recipe.id}`} class="group-hover:text-emerald-600 transition-colors">{recipe.data.title}</a>
            </h3>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
