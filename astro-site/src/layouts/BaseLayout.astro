---
import { ClientRouter } from "astro:transitions";
import "../assets/app.css";
const { title } = Astro.props;
---
<html lang="sv" class="bg-base-200" transition:name="root" transition:animate="slide">
  <head>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <ClientRouter />
  </head>
  <body class="py-12">
    <!-- RSS Feed Button -->
    <a href="/feed.xml" target="_blank" rel="noopener noreferrer" 
       class="fixed top-4 right-4 p-3 bg-base-100 border border-base-300 rounded-full shadow-lg hover:bg-primary/10 hover:border-primary transition-all duration-200 z-50 group"
       aria-label="RSS Feed">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v16h16M8.5 9V7a1 1 0 011-1h6a1 1 0 011 1v2M8.5 15v-2a1 1 0 011-1h6a1 1 0 011 1v2" />
      </svg>
    </a>

    <article class="">
      <slot /> <!-- your content is injected here -->
    </article>
  </body>
</html>